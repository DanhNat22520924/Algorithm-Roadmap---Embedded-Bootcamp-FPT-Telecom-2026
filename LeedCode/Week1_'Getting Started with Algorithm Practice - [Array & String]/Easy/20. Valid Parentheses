class Solution {
public:
    bool isValid(string s) {
        stack<char> st;

        for (char c : s) {

            if (c == '(' || c == '{' || c == '[') {  // nếu là ngoặc mở thì push vào stack
                st.push(c);
            }
            else {

                if (st.empty())
                    return false;   // nếu gặp ngoặc đóng mà stack rỗng nghĩa là không có ngoặc mở tương ứng

                if (c == ')') {    // kiểm tra từng loại ngoặc
                    if (st.top() != '(')
                        return false;
                    st.pop();
                }
                else if (c == '}') {
                    if (st.top() != '{')
                        return false;
                    st.pop();
                }
                else {
                    if (st.top() != '[')
                        return false;
                    st.pop();
                }
            }
        }

        return st.empty();    // sau khi duyệt hết chuỗi stack phải rỗng thì chuỗi mới hợp lệ
    }
};
