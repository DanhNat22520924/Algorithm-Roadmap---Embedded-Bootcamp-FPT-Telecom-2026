class Solution {
public:
    void merge(vector<int>& nums1, int m, vector<int>& nums2, int n) {
        int i = m - 1; // trỏ tới phần tử cuối của mảng nums1
        int j = n - 1; // i: trỏ tới phần tử cuối của mảng nums1
        int k = m + n - 1; //trỏ tới vị trí cuối của nums1
while (j >= 0) {
            if (i >= 0 && nums1[i] > nums2[j]) {
                nums1[k] = nums1[i];
                i--;
            } else {
                nums1[k] = nums2[j];
                j--;
            }
            k--; // Sau mỗi lần gán, giảm vị trí k
        }
    }
};
